# 개발 환경에서는 Vite proxy를 사용하므로 비워두면 됩니다.
# 프로덕션 빌드 시 백엔드 API 주소를 설정하세요.
VITE_API_URL=

# Cloudinary Upload Widget (클라이언트 전용, unsigned upload preset 사용)
# Cloudinary 대시보드 → Settings → Product environment credentials → Cloud name
VITE_CLOUDINARY_CLOUD_NAME=

# Cloudinary 대시보드 → Settings → Upload → Upload presets → unsigned preset 이름
VITE_CLOUDINARY_UPLOAD_PRESET=

# 선택: 업로드 폴더 경로 (예: products)
VITE_CLOUDINARY_FOLDER=

# 고객에게 안내할 무통장입금 계좌
VITE_BANK_ACCOUNT_BANK=
VITE_BANK_ACCOUNT_NUMBER=
VITE_BANK_ACCOUNT_HOLDER=
